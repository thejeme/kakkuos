#!/usr/bin/env bash
set -euo pipefail

SCREENSAVER_TIMEOUT="${KAKKU_SCREENSAVER_TIMEOUT:-300}"
LOCK_TIMEOUT="${KAKKU_LOCK_TIMEOUT:-900}"
LOCK_CMD="${KAKKU_LOCK_CMD:-dms ipc call lock lock || loginctl lock-session}"
SCREENSAVER_CMD="${KAKKU_SCREENSAVER_CMD:-kakku-screensaver --idle}"
SCREENSAVER_STOP_CMD="pkill -f 'kakku-screensaver --render' >/dev/null 2>&1 || true"

usage() {
  cat <<'EOF'
Usage:
  kakku-idle

Runs the KakkuOS idle policy:
  - start the visual screensaver after KAKKU_SCREENSAVER_TIMEOUT seconds
  - stop it on activity
  - hand off to the DMS lock screen after KAKKU_LOCK_TIMEOUT seconds

Defaults: KAKKU_SCREENSAVER_TIMEOUT=300, KAKKU_LOCK_TIMEOUT=900.
User overrides can be placed in ~/.config/kakku/idle.env when running
through kakku-idle.service.
EOF
}

case "${1:-run}" in
  run)
    ;;
  -h|--help|help)
    usage
    exit 0
    ;;
  *)
    echo "Unknown option: $1" >&2
    usage >&2
    exit 1
    ;;
esac

if ! command -v swayidle >/dev/null 2>&1; then
  echo "Missing command: swayidle" >&2
  exit 1
fi

if [[ -z "${WAYLAND_DISPLAY:-}" ]]; then
  for socket in "${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"/wayland-*; do
    if [[ -S "$socket" ]]; then
      export WAYLAND_DISPLAY="$(basename "$socket")"
      break
    fi
  done
fi

if [[ -z "${WAYLAND_DISPLAY:-}" ]]; then
  echo "No Wayland display is available yet." >&2
  exit 1
fi

for timeout_name in SCREENSAVER_TIMEOUT LOCK_TIMEOUT; do
  timeout_value="${!timeout_name}"
  if [[ ! "$timeout_value" =~ ^[0-9]+$ || "$timeout_value" -lt 1 ]]; then
    echo "Invalid $timeout_name: $timeout_value" >&2
    exit 1
  fi
done

exec swayidle -w \
  timeout "$SCREENSAVER_TIMEOUT" "$SCREENSAVER_CMD" \
  resume "$SCREENSAVER_STOP_CMD" \
  timeout "$LOCK_TIMEOUT" "$SCREENSAVER_STOP_CMD; $LOCK_CMD" \
  before-sleep "$SCREENSAVER_STOP_CMD; $LOCK_CMD"
