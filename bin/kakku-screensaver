#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  kakku-screensaver
  kakku-screensaver --idle
  kakku-screensaver --render

Starts niri-screensaver. This command is kept as KakkuOS compatibility glue
for keybinds and idle hooks.
EOF
}

run_screensaver() {
  if ! command -v niri-screensaver >/dev/null 2>&1; then
    echo "Missing command: install niri-screensaver to run kakku-screensaver." >&2
    exit 1
  fi

  exec niri-screensaver
}

case "${1:-start}" in
  start|--idle|--render)
    run_screensaver
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    echo "Unknown option: $1" >&2
    usage >&2
    exit 1
    ;;
esac
