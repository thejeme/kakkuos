#!/usr/bin/env bash
set -euo pipefail

SCREENSHOT_DIR="${XDG_PICTURES_DIR:-$HOME/Pictures}/Screenshots"

usage() {
  cat <<'EOF'
Usage:
  kakku-screenshot region
  kakku-screenshot full
EOF
}

timestamp() {
  date +%Y-%m-%d_%H-%M-%S
}

case "${1:-}" in
  region)
    grim -g "$(slurp)" - | swappy -f -
    ;;
  full)
    mkdir -p "$SCREENSHOT_DIR"
    grim "$SCREENSHOT_DIR/$(timestamp).png"
    ;;
  -h|--help|help|"")
    usage
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac

