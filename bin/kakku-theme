#!/usr/bin/env bash
set -euo pipefail

THEMES_DIR="${KAKKU_THEMES_DIR:-/usr/share/kakku/themes}"
CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"

usage() {
  cat <<'EOF'
Usage:
  kakku-theme list
  kakku-theme set <theme>
  kakku-theme current

Themes:
  matcha
  blueberry
  strawberry
  tiramisu
  funfetti
  velvet
  caramel
  mocha
  vanilla
  carrot
EOF
}

copy_theme_file() {
  local source="$1"
  local target="$2"

  if [[ -f "$source" ]]; then
    mkdir -p "$(dirname "$target")"
    cp "$source" "$target"
  fi
}

reload_session() {
  if command -v hyprctl >/dev/null 2>&1; then
    hyprctl reload >/dev/null 2>&1 || true
  fi

  if command -v makoctl >/dev/null 2>&1; then
    makoctl reload >/dev/null 2>&1 || true
  fi
}

list_themes() {
  local theme

  for theme in "$THEMES_DIR"/*; do
    [[ -d "$theme" ]] || continue
    basename "$theme"
  done
}

current_theme() {
  local current_file="$CONFIG_HOME/kakku-theme"

  if [[ -f "$current_file" ]]; then
    cat "$current_file"
  else
    echo "matcha"
  fi
}

set_theme() {
  local theme="$1"
  local theme_dir="$THEMES_DIR/$theme"

  if [[ ! -d "$theme_dir" ]]; then
    echo "Unknown Kakku theme: $theme" >&2
    echo >&2
    usage >&2
    exit 1
  fi

  copy_theme_file "$theme_dir/waybar.css" "$CONFIG_HOME/waybar/theme.css"
  copy_theme_file "$theme_dir/rofi.rasi" "$CONFIG_HOME/rofi/theme.rasi"
  copy_theme_file "$theme_dir/alacritty.toml" "$CONFIG_HOME/alacritty/theme.toml"
  copy_theme_file "$theme_dir/hyprland.conf" "$CONFIG_HOME/hypr/theme.conf"
  copy_theme_file "$theme_dir/mako" "$CONFIG_HOME/mako/config"
  copy_theme_file "$theme_dir/hyprlock.conf" "$CONFIG_HOME/hypr/hyprlock.conf"
  copy_theme_file "$theme_dir/hyprqt6engine.conf" "$CONFIG_HOME/hypr/hyprqt6engine.conf"
  copy_theme_file "$theme_dir/wallpaper.png" "$CONFIG_HOME/hypr/wallpaper.png"

  echo "$theme" > "$CONFIG_HOME/kakku-theme"
  reload_session
  echo "Kakku theme set to $theme."
  echo "Restart open Alacritty, Rofi, and Qt applications to fully apply it."
}

case "${1:-}" in
  list)
    list_themes
    ;;
  current)
    current_theme
    ;;
  set)
    if [[ -z "${2:-}" ]]; then
      usage >&2
      exit 1
    fi
    set_theme "$2"
    ;;
  -h|--help|help|"")
    usage
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
