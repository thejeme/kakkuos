#!/usr/bin/env bash
set -euo pipefail

PLUGIN_DIR="${KAKKU_DMS_PLUGIN_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/DankMaterialShell/plugins}"
DMS_CONFIG_DIR="${KAKKU_DMS_CONFIG_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/DankMaterialShell}"
DMS_PLUGIN_SETTINGS="$DMS_CONFIG_DIR/plugin_settings.json"
DMS_SETTINGS="$DMS_CONFIG_DIR/settings.json"
DMS_PLUGIN_DEFAULTS="${KAKKU_DMS_PLUGIN_DEFAULTS:-/usr/share/kakku/dms/plugin_settings.defaults.json}"
DMS_SETTINGS_DEFAULTS="${KAKKU_DMS_SETTINGS_DEFAULTS:-/usr/share/kakku/dms/settings.defaults.json}"
RESTART_DMS=1

usage() {
  cat <<'EOF'
Usage:
  kakku-dms-plugins [--no-restart]

Installs or updates the KakkuOS default DankMaterialShell plugins and defaults:
  - AIAssistant
  - Calculator
EOF
}

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --no-restart)
      RESTART_DMS=0
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

require_command() {
  local command_name="$1"

  if ! command -v "$command_name" >/dev/null 2>&1; then
    echo "Missing required command: $command_name" >&2
    exit 1
  fi
}

normalize_git_url() {
  local url="$1"
  printf '%s\n' "${url%.git}"
}

install_or_update_plugin() {
  local name="$1"
  local url="$2"
  local target="$PLUGIN_DIR/$name"
  local remote_url

  if [[ -d "$target/.git" ]]; then
    remote_url="$(git -C "$target" config --get remote.origin.url || true)"

    if [[ "$(normalize_git_url "$remote_url")" != "$(normalize_git_url "$url")" ]]; then
      echo "Skipping $name: $target already exists with a different git remote." >&2
      return
    fi

    echo "Updating DMS plugin: $name"
    git -C "$target" pull --ff-only
    return
  fi

  if [[ -e "$target" ]]; then
    echo "Skipping $name: $target already exists and is not a git checkout." >&2
    return
  fi

  echo "Installing DMS plugin: $name"
  git clone --depth 1 "$url" "$target"
}

merge_json_defaults() {
  local defaults="$1"
  local target="$2"
  local label="$3"
  local tmp

  if [[ ! -f "$defaults" ]]; then
    return
  fi

  if ! command -v jq >/dev/null 2>&1; then
    echo "Warning: jq is missing, skipping DMS $label defaults merge." >&2
    return
  fi

  mkdir -p "$DMS_CONFIG_DIR"
  tmp="$(mktemp)"

  if ! jq -e . "$defaults" >/dev/null 2>&1; then
    echo "Warning: $defaults is not valid JSON, skipping DMS $label defaults merge." >&2
    rm -f "$tmp"
    return
  fi

  if [[ -f "$target" ]]; then
    if ! jq -e . "$target" >/dev/null 2>&1; then
      echo "Warning: $target is not valid JSON, skipping DMS $label defaults merge." >&2
      rm -f "$tmp"
      return
    fi

    jq -s '.[0] * .[1]' "$defaults" "$target" > "$tmp"
  else
    jq . "$defaults" > "$tmp"
  fi

  mv "$tmp" "$target"
  echo "Merged DMS $label defaults into $target."
}

merge_plugin_defaults() {
  merge_json_defaults "$DMS_PLUGIN_DEFAULTS" "$DMS_PLUGIN_SETTINGS" "plugin"
}

merge_settings_defaults() {
  merge_json_defaults "$DMS_SETTINGS_DEFAULTS" "$DMS_SETTINGS" "settings"
}

require_command git
mkdir -p "$PLUGIN_DIR"

failed=0
install_or_update_plugin "AIAssistant" "https://github.com/devnullvoid/dms-ai-assistant.git" || failed=1
install_or_update_plugin "Calculator" "https://github.com/rochacbruno/DankCalculator.git" || failed=1
merge_plugin_defaults
merge_settings_defaults

if (( RESTART_DMS )) && command -v dms >/dev/null 2>&1; then
  dms restart >/dev/null 2>&1 || true
fi

echo "DMS plugin directory: $PLUGIN_DIR"

if (( failed )); then
  echo "One or more DMS plugins could not be installed or updated." >&2
  exit 1
fi

echo "DMS plugins are installed."
