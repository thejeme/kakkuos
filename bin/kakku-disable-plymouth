#!/usr/bin/env bash
set -euo pipefail

changed=0

require_root() {
  if [[ "${EUID:-$(id -u)}" -ne 0 ]]; then
    echo "Run as root: sudo kakku-disable-plymouth" >&2
    exit 1
  fi
}

backup_file() {
  local file="$1"

  if [[ -f "$file" && ! -f "$file.kakku.bak" ]]; then
    cp "$file" "$file.kakku.bak"
    echo "Backed up $file to $file.kakku.bak"
  fi
}

remove_mkinitcpio_plymouth() {
  local file="/etc/mkinitcpio.conf"
  local tmp

  [[ -f "$file" ]] || return 0
  tmp="$(mktemp)"

  sed -E '
    /^[[:space:]]*HOOKS=/ {
      s/[[:space:]]*plymouth([[:space:]]|\))/\1/g
      s/[[:space:]]+/ /g
      s/\( /(/g
      s/ \)/)/g
    }
  ' "$file" > "$tmp"

  if ! cmp -s "$file" "$tmp"; then
    backup_file "$file"
    cp "$tmp" "$file"
    changed=1
    echo "Removed plymouth hook from $file."
  fi

  rm -f "$tmp"
}

require_root

remove_mkinitcpio_plymouth

if (( changed )) && command -v mkinitcpio >/dev/null 2>&1; then
  mkinitcpio -P
elif (( ! changed )); then
  echo "Plymouth boot splash already disabled."
fi

echo "Plymouth boot splash disable step completed. Reboot to verify."
