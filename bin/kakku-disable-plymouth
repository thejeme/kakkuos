#!/usr/bin/env bash
set -euo pipefail

changed=0

require_root() {
  if [[ "${EUID:-$(id -u)}" -ne 0 ]]; then
    echo "Run as root: sudo kakku-disable-plymouth" >&2
    exit 1
  fi
}

backup_file() {
  local file="$1"

  if [[ -f "$file" && ! -f "$file.kakku.bak" ]]; then
    cp "$file" "$file.kakku.bak"
    echo "Backed up $file to $file.kakku.bak"
  fi
}

remove_words() {
  local file="$1"
  shift
  local tmp

  [[ -f "$file" ]] || return 0
  tmp="$(mktemp)"
  cp "$file" "$tmp"

  for word in "$@"; do
    sed -i -E "s/\\<${word}\\>//g; s/[[:space:]]+/ /g; s/=\" /=\"/g; s/ \"/\"/g; s/[[:space:]]+$//" "$tmp"
  done

  if ! cmp -s "$file" "$tmp"; then
    backup_file "$file"
    cp "$tmp" "$file"
    changed=1
    echo "Removed splash boot parameters from $file."
  fi

  rm -f "$tmp"
}

remove_mkinitcpio_plymouth() {
  local file="/etc/mkinitcpio.conf"
  local tmp

  [[ -f "$file" ]] || return 0
  tmp="$(mktemp)"

  sed -E '
    /^[[:space:]]*HOOKS=/ {
      s/[[:space:]]*plymouth([[:space:]]|\))/\1/g
      s/[[:space:]]+/ /g
      s/\( /(/g
      s/ \)/)/g
    }
  ' "$file" > "$tmp"

  if ! cmp -s "$file" "$tmp"; then
    backup_file "$file"
    cp "$tmp" "$file"
    changed=1
    echo "Removed plymouth hook from $file."
  fi

  rm -f "$tmp"
}

require_root

remove_mkinitcpio_plymouth

remove_words /etc/default/grub splash quiet
remove_words /etc/default/limine splash quiet

if [[ -d /boot/loader/entries ]]; then
  for entry in /boot/loader/entries/*.conf; do
    [[ -f "$entry" ]] || continue
    remove_words "$entry" splash quiet
  done
fi

if (( changed )) && command -v mkinitcpio >/dev/null 2>&1; then
  mkinitcpio -P
elif (( ! changed )); then
  echo "Plymouth boot splash already disabled."
fi

if command -v grub-mkconfig >/dev/null 2>&1 && [[ -f /etc/default/grub ]]; then
  echo "GRUB users should regenerate grub.cfg if needed, for example:"
  echo "  sudo grub-mkconfig -o /boot/grub/grub.cfg"
fi

echo "Plymouth boot splash disable step completed. Reboot to verify."
