#!/usr/bin/env bash
set -euo pipefail

require_root() {
  if [[ "${EUID:-$(id -u)}" -ne 0 ]]; then
    echo "Run as root: sudo kakku-disable-plymouth" >&2
    exit 1
  fi
}

backup_file() {
  local file="$1"

  if [[ -f "$file" && ! -f "$file.kakku.bak" ]]; then
    cp "$file" "$file.kakku.bak"
    echo "Backed up $file to $file.kakku.bak"
  fi
}

remove_words() {
  local file="$1"
  shift

  [[ -f "$file" ]] || return 0
  backup_file "$file"

  for word in "$@"; do
    sed -i -E "s/(^|[[:space:]])${word}([[:space:]]|$)/ /g; s/[[:space:]]+/ /g" "$file"
  done
}

require_root

if [[ -f /etc/mkinitcpio.conf ]]; then
  backup_file /etc/mkinitcpio.conf
  sed -i -E 's/[[:space:]]*plymouth[[:space:]]*/ /g; s/HOOKS=\((.*)\)/HOOKS=(\1)/' /etc/mkinitcpio.conf
  echo "Removed plymouth hook from /etc/mkinitcpio.conf when present."
fi

remove_words /etc/default/grub splash quiet
remove_words /etc/default/limine splash quiet

if [[ -d /boot/loader/entries ]]; then
  for entry in /boot/loader/entries/*.conf; do
    [[ -f "$entry" ]] || continue
    remove_words "$entry" splash quiet
  done
fi

if command -v mkinitcpio >/dev/null 2>&1; then
  mkinitcpio -P
fi

if command -v grub-mkconfig >/dev/null 2>&1 && [[ -f /etc/default/grub ]]; then
  echo "GRUB users should regenerate grub.cfg if needed, for example:"
  echo "  sudo grub-mkconfig -o /boot/grub/grub.cfg"
fi

echo "Plymouth boot splash disable step completed. Reboot to verify."

