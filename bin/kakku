#!/usr/bin/env bash
set -euo pipefail

CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
KAKKU_SHARE="${KAKKU_SHARE:-/usr/share/kakku}"

usage() {
  cat <<'EOF'
Usage:
  kakku help
  kakku info
  kakku doctor
  kakku services
  kakku keybinds
  kakku paths
  kakku packages
  kakku update
  kakku defaults
  kakku dms-plugins
  kakku disable-plymouth
  kakku version
EOF
}

has_command() {
  command -v "$1" >/dev/null 2>&1
}

check_command() {
  local command_name="$1"

  if has_command "$command_name"; then
    echo "ok   command: $command_name"
  else
    echo "miss command: $command_name"
    return 1
  fi
}

check_path() {
  local path="$1"

  if [[ -e "$path" ]]; then
    echo "ok   path: $path"
  else
    echo "miss path: $path"
    return 1
  fi
}

check_optional_path() {
  local path="$1"

  if [[ -e "$path" ]]; then
    echo "ok   optional path: $path"
  else
    echo "warn optional path missing: $path"
  fi
}

check_service_enabled() {
  local service="$1"

  if has_command systemctl && systemctl is-enabled "$service" >/dev/null 2>&1; then
    echo "ok   service enabled: $service"
  else
    echo "warn service not enabled: $service"
  fi
}

check_user_service_available() {
  local service="$1"

  if ! has_command systemctl; then
    echo "warn user service unchecked: $service"
    return 0
  fi

  if systemctl --user list-unit-files "$service" --no-legend 2>/dev/null | grep -q "^$service"; then
    echo "ok   user service available: $service"
  else
    echo "warn user service not found: $service"
  fi
}

check_login_shell() {
  local shell_path=""

  if has_command getent; then
    shell_path="$(getent passwd "$USER" 2>/dev/null | awk -F: '{print $7}')"
  fi

  case "$shell_path" in
    /usr/bin/fish|/bin/fish)
      echo "ok   login shell: $shell_path"
      ;;
    "")
      echo "warn login shell unchecked"
      ;;
    *)
      echo "warn login shell is $shell_path, expected fish"
      ;;
  esac
}

check_niri_config() {
  local config="$CONFIG_HOME/niri/config.kdl"

  check_path "$config" || return 1

  if ! has_command niri; then
    return 1
  fi

  if niri validate -c "$config" >/dev/null 2>&1; then
    echo "ok   niri config validates"
  else
    echo "warn niri config validation failed or unsupported"
  fi
}

check_xdg_default() {
  local mime_type="$1"
  shift
  local expected=("$@")
  local current=""
  local candidate

  if ! has_command xdg-mime; then
    echo "warn xdg default unchecked: $mime_type"
    return 0
  fi

  current="$(xdg-mime query default "$mime_type" 2>/dev/null || true)"
  for candidate in "${expected[@]}"; do
    if [[ "$current" == "$candidate" ]]; then
      echo "ok   xdg default: $mime_type -> $current"
      return 0
    fi
  done

  echo "miss xdg default: $mime_type -> ${current:-unset}"
  return 1
}

check_browser_policies() {
  local failed=0
  local target
  local targets=(
    /opt/zen-browser-bin/distribution/policies.json
    /usr/lib/zen-browser/distribution/policies.json
    /usr/lib/zen-browser-bin/distribution/policies.json
    /usr/lib/firefox/distribution/policies.json
  )

  check_path "$KAKKU_SHARE/browser/policies.json" || failed=1
  check_path /usr/share/libalpm/hooks/kakku-browser-policies.hook || failed=1

  for target in "${targets[@]}"; do
    if [[ -f "$target" ]]; then
      echo "ok   browser policy installed: $target"
      return "$failed"
    fi
  done

  echo "warn browser policy not installed into a browser distribution directory"
  return "$failed"
}

check_dms_plugin() {
  local plugin_dir="$1"
  local plugin_id="$2"
  local plugin_path="$CONFIG_HOME/DankMaterialShell/plugins/$plugin_dir/plugin.json"
  local settings_file="$CONFIG_HOME/DankMaterialShell/plugin_settings.json"

  check_path "$plugin_path" || return 1

  if [[ -f "$settings_file" ]] && has_command jq; then
    if jq -e --arg id "$plugin_id" '.[$id].enabled == true' "$settings_file" >/dev/null 2>&1; then
      echo "ok   DMS plugin enabled: $plugin_id"
    else
      echo "warn DMS plugin not enabled in settings: $plugin_id"
    fi
  fi
}

check_dms_ipc_bindings() {
  local config="$CONFIG_HOME/niri/config.kdl"
  local failed=0
  local binding
  local bindings=(
    'dms" "ipc" "call" "spotlight" "toggle'
    'dms" "ipc" "call" "clipboard" "toggle'
    'dms" "ipc" "call" "notifications" "toggle'
    'dms" "ipc" "call" "settings" "focusOrToggle'
    'dms" "ipc" "call" "dankdash" "wallpaper'
    'dms" "ipc" "call" "plugins" "toggle" "aiAssistant'
    'dms" "ipc" "call" "spotlight" "openQuery" "="'
    'dms" "ipc" "call" "lock" "lock'
    'dms" "ipc" "call" "audio" "increment'
    'dms" "ipc" "call" "brightness" "increment'
  )

  if [[ ! -f "$config" ]]; then
    return 1
  fi

  for binding in "${bindings[@]}"; do
    if ! grep -q "$binding" "$config"; then
      echo "miss DMS keybind command: $binding"
      failed=1
    fi
  done

  if (( failed == 0 )); then
    echo "ok   DMS IPC keybind commands"
  fi

  return "$failed"
}

show_service_status() {
  local service="$1"
  local state="unknown"
  local enabled="unknown"

  if has_command systemctl; then
    state="$(systemctl is-active "$service" 2>/dev/null || true)"
    enabled="$(systemctl is-enabled "$service" 2>/dev/null || true)"
  fi

  printf '%-16s active=%-10s enabled=%s\n' "$service" "$state" "$enabled"
}

show_services() {
  for service in NetworkManager bluetooth docker tailscaled power-profiles-daemon; do
    show_service_status "$service"
  done
}

show_keybinds() {
  cat <<'EOF'
KakkuOS keybindings:
  Super+Enter       Open terminal
  Super+Space/D     Open app launcher
  Super+A           Toggle AI Assistant
  Super+E           Open file manager
  Super+Shift+E     Open Yazi in terminal
  Super+Shift+C     Open Calculator query
  Super+Q           Close active window
  Super+Shift+Q     Exit niri
  Super+Shift+T     Toggle floating
  Super+W           Toggle tabbed column
  Super+Alt+L       Lock screen
  Super+Comma       Open DMS settings
  Super+V           Open clipboard
  Super+N           Open notifications
  Print             Screenshot picker
  Ctrl+Print        Screen screenshot to ~/Pictures/Screenshots
  Alt+Print         Window screenshot to ~/Pictures/Screenshots
  Super+1..9        Switch workspace
  Super+Shift+1..9  Move column to workspace
  Super+Arrows      Move focus
  Super+Shift+Arrows Move window or column
  Volume keys       Adjust/mute audio
  Media keys        Play/pause/next/previous
  Brightness keys   Adjust display brightness
EOF
}

show_info() {
  echo "KakkuOS"
  echo

  if [[ -f /etc/os-release ]]; then
    . /etc/os-release
    echo "Base: ${PRETTY_NAME:-unknown}"
  fi

  if has_command uname; then
    echo "Kernel: $(uname -r)"
  fi

  if has_command niri; then
    echo "Compositor: $(niri --version 2>/dev/null || echo niri)"
  fi

  if has_command dms; then
    echo "Shell: DankMaterialShell"
  fi

}

show_paths() {
  cat <<EOF
Kakku paths:
  Config home:        $CONFIG_HOME
  niri config:        $CONFIG_HOME/niri
  DMS config:         $CONFIG_HOME/DankMaterialShell
  Shared files:       $KAKKU_SHARE
  Backgrounds:        /usr/share/backgrounds/kakku
EOF
}

show_packages() {
  local repo_packages="/usr/share/kakku/packages"

  if [[ -d "$repo_packages/profiles" ]]; then
    echo "Package profiles:"
    find "$repo_packages/profiles" -maxdepth 1 -type f -name '*.txt' -printf '  %f\n' | sort
  else
    echo "Package profiles are available in the Kakku source repo under packages/profiles/."
  fi

  echo
  echo "AUR packages are listed in packages/aur.txt in the Kakku source repo."
}

run_doctor() {
  local failed=0

  for command_name in niri dms xwayland-satellite ghostty playerctl kakku kakku-defaults kakku-browser-policies kakku-dms-plugins yazi btop fish zathura; do
    check_command "$command_name" || failed=1
  done

  check_niri_config || failed=1
  check_path "/usr/share/backgrounds/kakku/wallpaper.png" || failed=1
  check_path "$CONFIG_HOME/fish/config.fish" || failed=1
  check_optional_path "$HOME/.zshrc"
  check_path "$CONFIG_HOME/DankMaterialShell/plugins" || failed=1

  check_dms_plugin AIAssistant aiAssistant || failed=1
  check_dms_plugin Calculator calculator || failed=1
  check_dms_ipc_bindings || failed=1

  check_xdg_default application/pdf org.pwmt.zathura.desktop zathura.desktop || failed=1
  check_xdg_default image/png imv.desktop || failed=1
  check_xdg_default text/html zen-browser.desktop zen.desktop zen-browser-bin.desktop firefox.desktop || failed=1
  check_xdg_default x-scheme-handler/http zen-browser.desktop zen.desktop zen-browser-bin.desktop firefox.desktop || failed=1
  check_xdg_default x-scheme-handler/https zen-browser.desktop zen.desktop zen-browser-bin.desktop firefox.desktop || failed=1

  check_browser_policies || failed=1
  check_login_shell

  check_service_enabled NetworkManager
  check_service_enabled bluetooth
  check_service_enabled greetd
  check_service_enabled docker
  check_service_enabled tailscaled
  check_service_enabled power-profiles-daemon
  check_user_service_available dms.service

  if (( failed )); then
    echo
    echo "Kakku doctor found missing required commands or paths."
    exit 1
  fi

  echo
  echo "Kakku doctor completed."
}

run_update() {
  if ! has_command sudo || ! has_command pacman; then
    echo "kakku update requires sudo and pacman." >&2
    exit 1
  fi

  echo "Updating repo packages with pacman..."
  sudo pacman -Syu

  if has_command paru; then
    echo
    echo "Updating AUR packages with paru..."
    paru -Sua
  elif has_command yay; then
    echo
    echo "Updating AUR packages with yay..."
    yay -Sua
  else
    echo
    echo "No AUR helper found. Skipping AUR updates."
  fi

  echo
  echo "Update complete. Reboot if kernel, driver, systemd, Mesa, or core system packages changed."
}

case "${1:-help}" in
  help|-h|--help)
    usage
    ;;
  info)
    show_info
    ;;
  doctor)
    run_doctor
    ;;
  services)
    show_services
    ;;
  keybinds)
    show_keybinds
    ;;
  paths)
    show_paths
    ;;
  packages)
    show_packages
    ;;
  update)
    run_update
    ;;
  defaults)
    kakku-defaults
    ;;
  dms-plugins)
    kakku-dms-plugins
    ;;
  disable-plymouth)
    sudo kakku-disable-plymouth
    ;;
  version)
    echo "KakkuOS 0.1.0"
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
