#!/usr/bin/env bash
set -euo pipefail

CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
KAKKU_SHARE="${KAKKU_SHARE:-/usr/share/kakku}"
KAKKU_BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat <<'EOF'
Usage:
  kakku help
  kakku info
  kakku doctor [--fix]
  kakku services
  kakku keybinds
  kakku paths
  kakku packages
  kakku screensaver
  kakku idle
  kakku update
  kakku defaults
  kakku browser-theme
  kakku version
EOF
}

has_command() {
  command -v "$1" >/dev/null 2>&1
}

check_command() {
  local command_name="$1"

  if has_command "$command_name"; then
    echo "ok   command: $command_name"
  else
    echo "miss command: $command_name"
    return 1
  fi
}

run_kakku_helper() {
  local helper="$1"
  shift

  if [[ -x "$KAKKU_BIN_DIR/$helper" ]]; then
    "$KAKKU_BIN_DIR/$helper" "$@"
  else
    "$helper" "$@"
  fi
}

run_as_root() {
  if (( EUID == 0 )); then
    "$@"
  else
    if ! has_command sudo; then
      echo "warn sudo is missing" >&2
      return 1
    fi

    sudo "$@"
  fi
}

target_login_user() {
  printf '%s\n' "${KAKKU_TARGET_USER:-${SUDO_USER:-$USER}}"
}

check_path() {
  local path="$1"

  if [[ -e "$path" ]]; then
    echo "ok   path: $path"
  else
    echo "miss path: $path"
    return 1
  fi
}

check_optional_path() {
  local path="$1"

  if [[ -e "$path" ]]; then
    echo "ok   optional path: $path"
  else
    echo "warn optional path missing: $path"
  fi
}

check_service_enabled() {
  local service="$1"

  if has_command systemctl && systemctl is-enabled "$service" >/dev/null 2>&1; then
    echo "ok   service enabled: $service"
  else
    echo "warn service not enabled: $service"
  fi
}

check_user_service_available() {
  local service="$1"

  if ! has_command systemctl; then
    echo "warn user service unchecked: $service"
    return 0
  fi

  if systemctl --user list-unit-files "$service" --no-legend 2>/dev/null | grep -q "^$service"; then
    echo "ok   user service available: $service"
  else
    echo "warn user service not found: $service"
  fi
}

check_user_service_enabled() {
  local service="$1"

  if ! has_command systemctl; then
    echo "warn user service unchecked: $service"
    return 0
  fi

  if systemctl --user is-enabled "$service" >/dev/null 2>&1; then
    echo "ok   user service enabled: $service"
  else
    echo "warn user service not enabled: $service"
  fi
}

check_login_shell() {
  local shell_path=""

  if has_command getent; then
    shell_path="$(getent passwd "$USER" 2>/dev/null | awk -F: '{print $7}')"
  fi

  case "$shell_path" in
    /usr/bin/fish|/bin/fish)
      echo "ok   login shell: $shell_path"
      ;;
    "")
      echo "warn login shell unchecked"
      ;;
    *)
      echo "warn login shell is $shell_path, expected fish"
      ;;
  esac
}

check_xdg_default() {
  local mime_type="$1"
  shift
  local expected=("$@")
  local current=""
  local candidate

  if ! has_command xdg-mime; then
    echo "warn xdg default unchecked: $mime_type"
    return 0
  fi

  current="$(xdg-mime query default "$mime_type" 2>/dev/null || true)"
  for candidate in "${expected[@]}"; do
    if [[ "$current" == "$candidate" ]]; then
      echo "ok   xdg default: $mime_type -> $current"
      return 0
    fi
  done

  echo "miss xdg default: $mime_type -> ${current:-unset}"
  return 1
}

check_browser_policies() {
  local failed=0
  local target
  local targets=(
    /opt/zen-browser-bin/distribution/policies.json
    /usr/lib/zen-browser/distribution/policies.json
    /usr/lib/zen-browser-bin/distribution/policies.json
    /usr/lib/firefox/distribution/policies.json
  )

  check_path "$KAKKU_SHARE/browser/policies.json" || failed=1

  for target in "${targets[@]}"; do
    if [[ -f "$target" ]]; then
      echo "ok   browser policy installed: $target"
      return "$failed"
    fi
  done

  echo "warn browser policy not installed into a browser distribution directory"
  return "$failed"
}

copy_missing_path() {
  local source="$1"
  local target="$2"

  if [[ -e "$target" ]]; then
    echo "skip exists: $target"
    return 0
  fi

  if [[ ! -e "$source" ]]; then
    echo "warn missing source: $source"
    return 0
  fi

  mkdir -p "$(dirname "$target")"
  cp -a "$source" "$target"
  echo "fix  installed missing path: $target"
}

run_fix_step() {
  local label="$1"
  shift

  echo "fix  $label"
  if "$@"; then
    echo "ok   $label"
  else
    echo "warn $label failed"
  fi
}

fix_user_dirs() {
  mkdir -p "$CONFIG_HOME" "$HOME/Pictures/Screenshots"

  if has_command xdg-user-dirs-update; then
    xdg-user-dirs-update || true
  fi
}

fix_missing_user_configs() {
  copy_missing_path /etc/skel/.config/fish "$CONFIG_HOME/fish"
  copy_missing_path /etc/skel/.config/starship "$CONFIG_HOME/starship"
  copy_missing_path /etc/skel/.config/niri "$CONFIG_HOME/niri"
  copy_missing_path /etc/skel/.config/nvim "$CONFIG_HOME/nvim"
  copy_missing_path /etc/skel/.config/DankMaterialShell "$CONFIG_HOME/DankMaterialShell"
  copy_missing_path /etc/skel/.zshrc "$HOME/.zshrc"
  copy_missing_path /etc/skel/.bashrc "$HOME/.bashrc"
}

fix_defaults() {
  if has_command kakku-defaults; then
    run_kakku_helper kakku-defaults
  else
    echo "warn kakku-defaults is missing"
  fi
}

fix_browser_policies() {
  if has_command kakku-browser-policies; then
    run_kakku_helper kakku-browser-policies
  else
    echo "warn kakku-browser-policies is missing"
  fi
}

fix_browser_theme() {
  if has_command kakku-browser-theme; then
    run_kakku_helper kakku-browser-theme
  else
    echo "warn kakku-browser-theme is missing"
  fi
}

fix_login_shell() {
  local current_shell=""
  local fish_path=""
  local target_user=""

  if has_command fish; then
    fish_path="$(command -v fish)"
  else
    echo "warn fish is missing"
    return 0
  fi

  target_user="$(target_login_user)"
  if [[ -z "$target_user" ]] || ! id "$target_user" >/dev/null 2>&1; then
    echo "warn cannot set login shell, unknown user: ${target_user:-unset}"
    return 0
  fi

  if has_command getent; then
    current_shell="$(getent passwd "$target_user" 2>/dev/null | awk -F: '{print $7}')"
  fi

  if [[ "$current_shell" == "$fish_path" || "$current_shell" == "/bin/fish" ]]; then
    return 0
  fi

  if [[ ! -f /etc/shells ]] || ! grep -Fxq "$fish_path" /etc/shells; then
    printf '%s\n' "$fish_path" | run_as_root tee -a /etc/shells >/dev/null || return 1
  fi

  if has_command usermod; then
    run_as_root usermod -s "$fish_path" "$target_user"
  elif has_command chsh; then
    run_as_root chsh -s "$fish_path" "$target_user"
  else
    echo "warn usermod and chsh are missing"
  fi
}

system_unit_exists() {
  local service="$1"

  systemctl list-unit-files "$service" --no-legend 2>/dev/null | grep -q "^$service"
}

fix_core_services() {
  local service
  local sudo_cmd=()

  if ! has_command systemctl; then
    echo "warn systemctl is missing"
    return 0
  fi

  if (( EUID != 0 )); then
    if ! has_command sudo; then
      echo "warn sudo is missing"
      return 0
    fi
    sudo_cmd=(sudo)
  fi

  for service in NetworkManager.service bluetooth.service greetd.service ananicy-cpp.service power-profiles-daemon.service ufw.service; do
    if system_unit_exists "$service"; then
      "${sudo_cmd[@]}" systemctl enable "$service" || true
    else
      echo "warn service unit missing: $service"
    fi
  done

  if has_command kakku-firewall-defaults; then
    "${sudo_cmd[@]}" kakku-firewall-defaults || true
  fi
}

fix_user_services() {
  if ! has_command systemctl; then
    echo "warn systemctl is missing"
    return 0
  fi

  systemctl --user daemon-reload 2>/dev/null || true
  systemctl --user enable --now dms.service 2>/dev/null || true
  systemctl --user enable --now kakku-idle.service 2>/dev/null || true
  systemctl --user enable --now dsearch.service 2>/dev/null || true
}

show_service_status() {
  local service="$1"
  local state="unknown"
  local enabled="unknown"

  if has_command systemctl; then
    state="$(systemctl is-active "$service" 2>/dev/null || true)"
    enabled="$(systemctl is-enabled "$service" 2>/dev/null || true)"
  fi

  printf '%-16s active=%-10s enabled=%s\n' "$service" "$state" "$enabled"
}

show_services() {
  for service in NetworkManager bluetooth docker tailscaled ananicy-cpp power-profiles-daemon ufw; do
    show_service_status "$service"
  done
}

show_keybinds() {
  cat <<'EOF'
KakkuOS keybindings:
  Help and overview
    Super+§                       Show keybindings help
    Super+Tab                     Toggle workspace overview
    Super+Alt+S                   Start Kakku screensaver
    Super+Escape                  Toggle shortcut inhibition

  Shell and applications
    Super+T                       Open Ghostty terminal
    Super+E                       Open Dolphin files
    Super+B                       Open Zen browser
    Super+Shift+B                 Open Chrome fallback browser
    Super+D                       Open Discord/Vesktop
    Super+S                       Open Steam
    Super+Space                   Open app launcher
    Super+V                       Open clipboard
    Super+M / Ctrl+Alt+Delete     Open task manager
    Super+X                       Open power menu
    Super+Comma                   Open DMS settings
    Super+Y                       Open wallpaper browser
    Super+N                       Open notifications
    Super+Shift+N                 Open notepad
    Super+Alt+L                   Lock screen
    Super+Shift+P                 Pick screen color to clipboard
    Ctrl+Alt+End                  Exit niri

  Windows and columns
    Super+Q                       Close active window
    Super+F                       Maximize column
    Super+Shift+F                 Fullscreen window
    Super+Shift+T                 Toggle floating
    Super+Shift+V                 Switch floating/tiling focus
    Super+W                       Toggle tabbed column
    Super+Alt+Left/Right          Consume or expel window
    Super+.                       Expel window from column
    Super+Home / Super+End        Focus first/last column
    Super+Ctrl+Home/End           Move column to first/last

  Focus and movement
    Super+Left/Right or H/L       Focus column or monitor
    Super+Up/Down or J/K          Focus window or workspace
    Super+Shift+Left/Right or H/L Move column or monitor
    Super+Shift+Up/Down or J/K    Move window
    Super+Ctrl+Left/Right or H/L  Focus monitor
    Super+Ctrl+J/K                Focus monitor down/up
    Super+Shift+Ctrl+Arrows       Move column to monitor
    Super+Shift+Ctrl+H/J/K/L      Move column to monitor

  Workspaces
    Super+PageUp/PageDown         Focus workspace up/down
    Super+U/I                     Focus workspace down/up
    Super+Ctrl+Up/Down or U/I     Move column to workspace
    Super+1..9                    Switch workspace by position
    Super+Shift+1..9              Move column to workspace position

  Mouse wheel
    Super+WheelUp/Down            Focus workspace up/down
    Super+Ctrl+WheelUp/Down       Move column to workspace
    Super+WheelLeft/Right         Focus column
    Super+Ctrl+WheelLeft/Right    Move column
    Super+Shift+WheelUp/Down      Focus column
    Super+Ctrl+Shift+WheelUp/Down Move column

  Layout and config
    Super+R                       Switch preset column width
    Super+Shift+R                 Switch preset window height
    Super+Ctrl+R                  Reset window height
    Super+Alt+R                   Reload niri config
    Super+Ctrl+F                  Expand column to available width
    Super+C                       Center column
    Super+Ctrl+C                  Center visible columns
    Super+- / Super+= / Super++   Adjust column width
    Super+numpad-                 Decrease column width
    Super+Shift+- / Super+Ctrl+=  Adjust window height
    Super+numpad+                 Increase column width
    Super+Ctrl+numpad-            Decrease window height
    Super+Ctrl+numpad+            Increase window height

  Screenshots
    Print / XF86Launch1           Pick area, copied and saved without cursor
    Ctrl+Print / Ctrl+XF86Launch1 Screenshot screen without cursor
    Alt+Print / Alt+XF86Launch1   Screenshot window without cursor

  Media and hardware
    Volume keys                   Adjust/mute audio
    Mic mute key                  Toggle microphone mute
    Media keys                    Play/pause/previous/next
    Ctrl+Volume keys              Seek media
    Brightness keys               Adjust display brightness
    Alt+Tab / Alt+Shift+Tab       Cycle windows on output
EOF
}

show_info() {
  echo "KakkuOS"
  echo

  if [[ -f /etc/os-release ]]; then
    . /etc/os-release
    echo "Base: ${PRETTY_NAME:-unknown}"
  fi

  if has_command uname; then
    echo "Kernel: $(uname -r)"
  fi

  if has_command niri; then
    echo "Compositor: $(niri --version 2>/dev/null || echo niri)"
  fi

  if has_command dms; then
    echo "Shell: DankMaterialShell"
  fi

}

show_paths() {
  cat <<EOF
Kakku paths:
  Config home:        $CONFIG_HOME
  DMS config:         $CONFIG_HOME/DankMaterialShell
  Screensaver logo:   $CONFIG_HOME/kakku/screensaver.txt
  Shared files:       $KAKKU_SHARE
  Backgrounds:        /usr/share/backgrounds/kakku
EOF
}

show_packages() {
  local repo_packages="/usr/share/kakku/packages"

  if [[ -d "$repo_packages/profiles" ]]; then
    echo "Package profiles:"
    find "$repo_packages/profiles" -maxdepth 1 -type f -name '*.txt' -printf '  %f\n' | sort
  else
    echo "Package profiles are available in the Kakku source repo under packages/profiles/."
  fi

  echo
  echo "AUR packages are listed in packages/aur.txt in the Kakku source repo."
}

run_doctor_fix() {
  echo "Kakku doctor repair mode"
  echo

  run_fix_step "create user directories" fix_user_dirs
  run_fix_step "restore missing user configs from /etc/skel" fix_missing_user_configs
  run_fix_step "configure default applications" fix_defaults
  run_fix_step "install browser policies" fix_browser_policies
  run_fix_step "configure browser theme hooks" fix_browser_theme
  run_fix_step "set fish as login shell" fix_login_shell
  run_fix_step "enable core services" fix_core_services
  run_fix_step "enable user services" fix_user_services

  echo
  echo "Repair pass completed. Rechecking..."
  echo
}

run_doctor_checks() {
  local failed=0

  for command_name in niri dms dsearch xwayland-satellite ghostty swayidle kakku kakku-defaults kakku-browser-policies kakku-screensaver kakku-idle yazi btop fish zathura nvim codex; do
    check_command "$command_name" || failed=1
  done

  check_path "/usr/share/backgrounds/kakku/wallpaper.png" || failed=1
  check_path "/usr/share/backgrounds/kakku/kakku-default.png" || failed=1
  check_path "$KAKKU_SHARE/branding/logo.png" || failed=1
  check_path "$KAKKU_SHARE/dms/settings.defaults.json" || failed=1
  check_path "$KAKKU_SHARE/dms/themes/kakku/theme.json" || failed=1
  check_command dms-greeter || failed=1
  check_path "$KAKKU_SHARE/screensaver/kakku.txt" || failed=1
  check_path /usr/lib/systemd/user/kakku-idle.service || failed=1
  check_path "$CONFIG_HOME/DankMaterialShell/settings.json" || failed=1
  check_path "$CONFIG_HOME/fish/config.fish" || failed=1
  check_path "$CONFIG_HOME/niri/config.kdl" || failed=1
  check_path "$CONFIG_HOME/nvim/init.lua" || failed=1
  check_optional_path "$HOME/.zshrc"

  check_xdg_default application/pdf org.pwmt.zathura.desktop zathura.desktop || failed=1
  check_xdg_default image/png imv.desktop || failed=1
  check_xdg_default text/html zen-browser.desktop zen.desktop zen-browser-bin.desktop firefox.desktop || failed=1
  check_xdg_default x-scheme-handler/http zen-browser.desktop zen.desktop zen-browser-bin.desktop firefox.desktop || failed=1
  check_xdg_default x-scheme-handler/https zen-browser.desktop zen.desktop zen-browser-bin.desktop firefox.desktop || failed=1

  check_browser_policies || failed=1
  check_command kakku-browser-theme || failed=1
  check_login_shell

  check_service_enabled NetworkManager
  check_service_enabled bluetooth
  check_service_enabled greetd
  check_service_enabled docker
  check_service_enabled tailscaled
  check_service_enabled ananicy-cpp
  check_service_enabled power-profiles-daemon
  check_service_enabled ufw
  check_user_service_available dms.service
  check_user_service_available dsearch.service
  check_user_service_available kakku-idle.service
  check_user_service_enabled dms.service
  check_user_service_enabled dsearch.service
  check_user_service_enabled kakku-idle.service

  if (( failed )); then
    echo
    echo "Kakku doctor found missing required commands or paths."
    exit 1
  fi

  echo
  echo "Kakku doctor completed."
}

run_doctor() {
  local fix=0

  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --fix|fix)
        fix=1
        shift
        ;;
      -h|--help)
        usage
        return 0
        ;;
      *)
        echo "Unknown doctor option: $1" >&2
        usage >&2
        exit 1
        ;;
    esac
  done

  if (( fix )); then
    run_doctor_fix
  fi

  run_doctor_checks
}

run_update() {
  if ! has_command sudo || ! has_command pacman; then
    echo "kakku update requires sudo and pacman." >&2
    exit 1
  fi

  echo "Updating repo packages with pacman..."
  sudo pacman -Syu

  if has_command paru; then
    echo
    echo "Updating AUR packages with paru..."
    paru -Sua
  elif has_command yay; then
    echo
    echo "Updating AUR packages with yay..."
    yay -Sua
  else
    echo
    echo "No AUR helper found. Skipping AUR updates."
  fi

  echo
  echo "Update complete. Reboot if kernel, driver, systemd, Mesa, or core system packages changed."
}

case "${1:-help}" in
  help|-h|--help)
    usage
    ;;
  info)
    show_info
    ;;
  doctor)
    shift
    run_doctor "$@"
    ;;
  services)
    show_services
    ;;
  keybinds)
    show_keybinds
    ;;
  paths)
    show_paths
    ;;
  packages)
    show_packages
    ;;
  screensaver)
    shift
    run_kakku_helper kakku-screensaver "$@"
    ;;
  idle)
    shift
    run_kakku_helper kakku-idle "$@"
    ;;
  update)
    shift
    run_update
    ;;
  defaults)
    shift
    run_kakku_helper kakku-defaults "$@"
    ;;
  browser-theme)
    shift
    run_kakku_helper kakku-browser-theme "$@"
    ;;
  version)
    echo "KakkuOS 0.1.0"
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
