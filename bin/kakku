}

show_info() {
  echo "KakkuOS"
  echo

  if [[ -f /etc/os-release ]]; then
    . /etc/os-release
    echo "Base: ${PRETTY_NAME:-unknown}"
  fi

  if has_command uname; then
    echo "Kernel: $(uname -r)"
  fi

  if has_command niri; then
    echo "Compositor: $(niri --version 2>/dev/null || echo niri)"
  fi

  if has_command dms; then
    echo "Shell: DankMaterialShell"
  fi

}

print_command_output() {
  local label="$1"
  shift

  echo "$label:"
  if "$@" 2>/dev/null; then
    :
  else
    echo "  unavailable"
  fi
  echo
}

print_command_version() {
  local label="$1"
  local command_name="$2"
  shift 2

  if has_command "$command_name"; then
    printf '%-18s %s\n' "$label:" "$("$command_name" "$@" 2>/dev/null | head -n 1 || printf 'available')"
  else
    printf '%-18s %s\n' "$label:" "missing"
  fi
}

show_context() {
  echo "KakkuOS support context"
  echo "Generated: $(date -Is 2>/dev/null || date)"
  echo
  echo "This output is intended to paste into an AI chat or support request."
  echo "It avoids logs and personal file listings, but review it before sharing."
  echo

  echo "System:"
  if [[ -f /etc/os-release ]]; then
    . /etc/os-release
    printf '%-18s %s\n' "OS:" "${PRETTY_NAME:-unknown}"
    printf '%-18s %s\n' "OS ID:" "${ID:-unknown}"
  fi
  if has_command uname; then
    printf '%-18s %s\n' "Kernel:" "$(uname -r)"
    printf '%-18s %s\n' "Machine:" "$(uname -m)"
  fi
  printf '%-18s %s\n' "Session:" "${XDG_SESSION_TYPE:-unknown}"
  printf '%-18s %s\n' "Desktop:" "${XDG_CURRENT_DESKTOP:-unknown}"
  printf '%-18s %s\n' "Shell:" "${SHELL:-unknown}"
  echo

  echo "Versions:"
  print_command_version "kakku" kakku version
  print_command_version "niri" niri --version
  print_command_version "dms" dms version
  print_command_version "quickshell" quickshell --version
  print_command_version "ghostty" ghostty --version
  print_command_version "fish" fish --version
  echo

  echo "Important paths:"
  for path in \
    "$CONFIG_HOME/niri/config.kdl" \
    "$CONFIG_HOME/DankMaterialShell/settings.json" \
    "$CONFIG_HOME/fish/config.fish" \
    "$CONFIG_HOME/niri-screensaver/config" \
    "$KAKKU_SHARE/dms/settings.defaults.json" \
    "/usr/share/backgrounds/kakku"; do
    if [[ -e "$path" ]]; then
      printf 'ok   %s\n' "$path"
    else
      printf 'miss %s\n' "$path"
    fi
  done
  echo

  if has_command niri; then
    print_command_output "Niri outputs" niri msg outputs
  fi

  if has_command dms; then
    print_command_output "DMS outputs" dms randr
  fi

  echo "Services:"
  show_services
  echo

  echo "User services:"
  for service in dms.service dsearch.service; do
    if has_command systemctl; then
      printf '%-16s active=%-10s enabled=%s\n' "$service" "$(systemctl --user is-active "$service" 2>/dev/null || true)" "$(systemctl --user is-enabled "$service" 2>/dev/null || true)"
    else
      printf '%-16s unavailable\n' "$service"
    fi
  done
  echo

  echo "Useful next checks:"
  echo "  kakku doctor"
  echo "  niri validate -c ~/.config/niri/config.kdl"
  echo "  dms doctor"
}

show_context_json() {
  local os_name="" os_id="" kernel="" machine=""

  if [[ -f /etc/os-release ]]; then
    . /etc/os-release
    os_name="${PRETTY_NAME:-unknown}"
    os_id="${ID:-unknown}"
  fi

  if has_command uname; then
    kernel="$(uname -r)"
    machine="$(uname -m)"
  fi

  local niri_version="" dms_version="" ghostty_version="" fish_version=""
  niri_version="$(niri --version 2>/dev/null | head -n1 || true)"
  dms_version="$(dms version 2>/dev/null | head -n1 || true)"
  ghostty_version="$(ghostty --version 2>/dev/null | head -n1 || true)"
  fish_version="$(fish --version 2>/dev/null | head -n1 || true)"

  local paths_json="{"
  local first=1
  for path in \
    "$CONFIG_HOME/niri/config.kdl" \
    "$CONFIG_HOME/DankMaterialShell/settings.json" \
    "$CONFIG_HOME/fish/config.fish" \
    "$CONFIG_HOME/niri-screensaver/config" \
    "$KAKKU_SHARE/dms/settings.defaults.json" \
    "/usr/share/backgrounds/kakku"; do
    (( first )) || paths_json+=","
    first=0
    if [[ -e "$path" ]]; then
      paths_json+="\"$path\":true"
    else
      paths_json+="\"$path\":false"
    fi
  done
  paths_json+="}"

  local services_json="{"
  first=1
  for service in NetworkManager bluetooth docker tailscaled ananicy-cpp power-profiles-daemon ufw; do
    (( first )) || services_json+=","
    first=0
    local active="" enabled=""
    if has_command systemctl; then
      active="$(systemctl is-active "$service" 2>/dev/null || true)"
      enabled="$(systemctl is-enabled "$service" 2>/dev/null || true)"
    fi
    services_json+="\"$service\":{\"active\":\"$active\",\"enabled\":\"$enabled\"}"
  done
  services_json+="}"

  local user_services_json="{"
  first=1
  for service in dms.service dsearch.service; do
    (( first )) || user_services_json+=","
    first=0
    local active="" enabled=""
    if has_command systemctl; then
      active="$(systemctl --user is-active "$service" 2>/dev/null || true)"
      enabled="$(systemctl --user is-enabled "$service" 2>/dev/null || true)"
    fi
    user_services_json+="\"$service\":{\"active\":\"$active\",\"enabled\":\"$enabled\"}"
  done
  user_services_json+="}"

  local niri_config=""
  if [[ -f "$CONFIG_HOME/niri/config.kdl" ]]; then
    niri_config="$(cat "$CONFIG_HOME/niri/config.kdl")"
  fi

  local dms_settings=""
  if [[ -f "$CONFIG_HOME/DankMaterialShell/settings.json" ]]; then
    dms_settings="$(cat "$CONFIG_HOME/DankMaterialShell/settings.json")"
  fi

  local fish_config=""
  if [[ -f "$CONFIG_HOME/fish/config.fish" ]]; then
    fish_config="$(cat "$CONFIG_HOME/fish/config.fish")"
  fi

  local changelog_entries=""
  local changelog_file="$HOME/.local/share/kakku/changelog.jsonl"
  if [[ -f "$changelog_file" ]]; then
    changelog_entries="$(tail -n 20 "$changelog_file")"
  fi

  # Use jq if available for safe JSON encoding, otherwise use printf
  if has_command jq; then
    jq -n \
      --arg os "$os_name" \
      --arg os_id "$os_id" \
      --arg kernel "$kernel" \
      --arg machine "$machine" \
      --arg session "${XDG_SESSION_TYPE:-unknown}" \
      --arg desktop "${XDG_CURRENT_DESKTOP:-unknown}" \
      --arg shell "${SHELL:-unknown}" \
      --arg niri_ver "$niri_version" \
      --arg dms_ver "$dms_version" \
      --arg ghostty_ver "$ghostty_version" \
      --arg fish_ver "$fish_version" \
      --argjson paths "$paths_json" \
      --argjson services "$services_json" \
      --argjson user_services "$user_services_json" \
      --arg niri_config "$niri_config" \
      --arg dms_settings "$dms_settings" \
      --arg fish_config "$fish_config" \
      --arg changelog "$changelog_entries" \
      '{
        system: {os: $os, os_id: $os_id, kernel: $kernel, machine: $machine, session: $session, desktop: $desktop, shell: $shell},
        versions: {niri: $niri_ver, dms: $dms_ver, ghostty: $ghostty_ver, fish: $fish_ver},
        paths: $paths,
        services: $services,
        user_services: $user_services,
        config: {niri: $niri_config, dms_settings: $dms_settings, fish: $fish_config},
        recent_changes: $changelog
      }'
  else
    # Fallback: minimal JSON without proper escaping for config contents
    cat <<ENDJSON
{"system":{"os":"$os_name","os_id":"$os_id","kernel":"$kernel","machine":"$machine","session":"${XDG_SESSION_TYPE:-unknown}","desktop":"${XDG_CURRENT_DESKTOP:-unknown}","shell":"${SHELL:-unknown}"},"versions":{"niri":"$niri_version","dms":"$dms_version","ghostty":"$ghostty_version","fish":"$fish_version"},"paths":$paths_json,"services":$services_json,"user_services":$user_services_json}
ENDJSON
  fi
}

show_paths() {
  cat <<EOF
Kakku paths:
  Config home:        $CONFIG_HOME
  DMS config:         $CONFIG_HOME/DankMaterialShell
  Shared files:       $KAKKU_SHARE
  Backgrounds:        /usr/share/backgrounds/kakku
EOF
}

show_packages() {
  local repo_packages="/usr/share/kakku/packages"

  if [[ -d "$repo_packages/profiles" ]]; then
    echo "Package profiles:"
    find "$repo_packages/profiles" -maxdepth 1 -type f -name '*.txt' -printf '  %f\n' | sort
  else
    echo "Package profiles are available in the Kakku source repo under packages/profiles/."
  fi

  echo
  echo "AUR packages are listed in packages/aur.txt in the Kakku source repo."
}

run_doctor_fix() {
  echo "Kakku doctor repair mode"
  echo

  run_fix_step "create user directories" fix_user_dirs
  run_fix_step "restore missing user configs from /etc/skel" fix_missing_user_configs
  run_fix_step "configure default applications" fix_defaults
  run_fix_step "install browser policies" fix_browser_policies
  run_fix_step "configure browser theme hooks" fix_browser_theme
  run_fix_step "configure VS Code theme" fix_vscode_theme
  run_fix_step "install calccu calculator" fix_calccu
  run_fix_step "set fish as login shell" fix_login_shell
  run_fix_step "enable core services" fix_core_services
  run_fix_step "enable user services" fix_user_services

  echo
  echo "Repair pass completed. Rechecking..."
  echo
}

run_doctor_checks() {
  local failed=0

  for command_name in niri dms dsearch xwayland-satellite ghostty swayidle wf-recorder niri-screensaver niri-screensaver-ctl niri-focus-game kakku kakku-defaults kakku-browser-policies kakku-vscode-theme kakku-edit calccu yazi btop fish zathura nvim codex; do
    check_command "$command_name" || failed=1
  done

  check_path "/usr/share/backgrounds/kakku/wallpaper.png" || failed=1
  check_path "/usr/share/backgrounds/kakku/kakku-default.png" || failed=1
  check_path "$KAKKU_SHARE/branding/logo.png" || failed=1
  check_path "$KAKKU_SHARE/dms/settings.defaults.json" || failed=1
  check_path "$KAKKU_SHARE/dms/themes/kakku/theme.json" || failed=1
  check_command dms-greeter || failed=1
  check_path "$CONFIG_HOME/DankMaterialShell/settings.json" || failed=1
  check_path "$CONFIG_HOME/fish/config.fish" || failed=1
  check_path "$CONFIG_HOME/niri/config.kdl" || failed=1
  check_path "$CONFIG_HOME/niri-screensaver/config" || failed=1
  check_path "$CONFIG_HOME/nvim/init.lua" || failed=1
  check_optional_path "$HOME/.zshrc"

  check_xdg_default application/pdf org.pwmt.zathura.desktop zathura.desktop || failed=1
  check_xdg_default image/png imv.desktop || failed=1
  check_xdg_default text/html zen-browser.desktop zen.desktop zen-browser-bin.desktop firefox.desktop || failed=1
  check_xdg_default x-scheme-handler/http zen-browser.desktop zen.desktop zen-browser-bin.desktop firefox.desktop || failed=1
  check_xdg_default x-scheme-handler/https zen-browser.desktop zen.desktop zen-browser-bin.desktop firefox.desktop || failed=1

  check_browser_policies || failed=1
  check_command kakku-browser-theme || failed=1
  check_command kakku-vscode-theme || failed=1
  check_login_shell

  check_service_enabled NetworkManager
  check_service_enabled bluetooth
  check_service_enabled greetd
  check_service_enabled docker
  check_service_enabled tailscaled
  check_service_enabled ananicy-cpp
  check_service_enabled power-profiles-daemon
  check_service_enabled ufw
  check_user_service_available dms.service
  check_user_service_available dsearch.service
  check_user_service_enabled dms.service
  check_user_service_enabled dsearch.service

  if (( failed )); then
    echo
    echo "Kakku doctor found missing required commands or paths."
    exit 1
  fi

  echo
  echo "Kakku doctor completed."
}

run_doctor() {
  local fix=0

  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --fix|fix)
        fix=1
        shift
        ;;
      -h|--help)
        usage
        return 0
        ;;
      *)
        echo "Unknown doctor option: $1" >&2
        usage >&2
        exit 1
        ;;
    esac
  done

  if (( fix )); then
    run_doctor_fix
  fi

  run_doctor_checks
}

run_update() {
  if ! has_command sudo || ! has_command pacman; then
    echo "kakku update requires sudo and pacman." >&2
    exit 1
  fi

  echo "Updating repo packages with pacman..."
  sudo pacman -Syu

  if has_command paru; then
    echo
    echo "Updating AUR packages with paru..."
    paru -Sua
  elif has_command yay; then
    echo
    echo "Updating AUR packages with yay..."
    yay -Sua
  else
    echo
    echo "No AUR helper found. Skipping AUR updates."
  fi

  echo
  echo "Update complete. Reboot if kernel, driver, systemd, Mesa, or core system packages changed."
}

case "${1:-help}" in
  help|-h|--help)
    usage
    ;;
  info)
    show_info
    ;;
  context)
    shift
    if [[ "${1:-}" == "--json" ]]; then
      show_context_json
    else
      show_context
    fi
    ;;
  doctor)
    shift
    run_doctor "$@"
    ;;
  services)
    show_services
    ;;
  keybinds)
    show_keybinds
    ;;
  paths)
    show_paths
    ;;
  packages)
    show_packages
    ;;
  update)
    shift
    run_update
    ;;
  defaults)
    shift
    run_kakku_helper kakku-defaults "$@"
    ;;
  browser-theme)
    shift
    run_kakku_helper kakku-browser-theme "$@"
    ;;
  vscode-theme)
    shift
    run_kakku_helper kakku-vscode-theme "$@"
    ;;
  version)
    echo "KakkuOS 0.2.0"
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
