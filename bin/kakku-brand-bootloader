#!/usr/bin/env bash
set -euo pipefail

require_root() {
  if [[ "${EUID:-$(id -u)}" -ne 0 ]]; then
    echo "Run as root: sudo kakku-brand-bootloader" >&2
    exit 1
  fi
}

backup_file() {
  local file="$1"
  if [[ -f "$file" && ! -f "$file.kakku.bak" ]]; then
    cp "$file" "$file.kakku.bak"
    echo "Backed up $file to $file.kakku.bak"
  fi
}

replace_os_name() {
  local file="$1"
  [[ -f "$file" ]] || return 0

  backup_file "$file"

  # Restore from backup first if we messed up kernel paths previously
  if grep -q "kernel_path.*kakkuos" "$file" && [[ -f "$file.kakku.bak" ]]; then
    cp "$file.kakku.bak" "$file"
  fi

  # Safely replace user-facing menu titles only. Limine entries start with
  # "/" (for example "/+CachyOS" or "//linux-cachyos"), while kernel paths are
  # key/value lines and must keep linux-cachyos filenames intact.
  sed -i -E '/^[[:space:]]*\/+/ s/[Cc]achy[Oo][Ss]/KakkuOS/g' "$file"
  sed -i -E '/^[[:space:]]*\/+/ s/linux-cachyos/KakkuOS/g' "$file"
  sed -i -E '/^[[:space:]]*\/+/ s/\(KakkuOS\)//g' "$file"
  sed -i -E '/^[[:space:]]*\/+/ s/ - KakkuOS//g' "$file"

  sed -i -E '/^:/ s/[Cc]achy[Oo][Ss]/KakkuOS/g' "$file"
  sed -i -E '/^:/ s/linux-cachyos/KakkuOS/g' "$file"
  sed -i -E '/^:/ s/\(KakkuOS\)//g' "$file"
  sed -i -E '/^:/ s/ - KakkuOS//g' "$file"

  sed -i -E '/^title/ s/[Cc]achy[Oo][Ss]/KakkuOS/g' "$file"
  sed -i -E '/^title/ s/linux-cachyos/KakkuOS/g' "$file"

  sed -i -E '/^GRUB_DISTRIBUTOR/ s/[Cc]achy[Oo][Ss]/KakkuOS/g' "$file"

  # Clean up any weird dangling characters in menus
  sed -i -E '/^[[:space:]]*\/+/ s/ - $//g' "$file"
  sed -i -E '/^[[:space:]]*\/+/ s/ -$//g' "$file"
  sed -i -E '/^:/ s/ - $//g' "$file"
  sed -i -E '/^:/ s/ -$//g' "$file"

  echo "Safely branded bootloader menus in $file."
}

require_root

# For Limine
replace_os_name /limine.conf
replace_os_name /limine/limine.conf
replace_os_name /boot/limine.conf
replace_os_name /boot/limine/limine.conf
replace_os_name /boot/efi/EFI/limine/limine.conf
replace_os_name /boot/efi/EFI/Limine/limine.conf
replace_os_name /boot/EFI/limine/limine.conf
replace_os_name /boot/EFI/Limine/limine.conf
if [[ -d /etc/limine ]]; then
  for entry in /etc/limine/*.conf; do
    replace_os_name "$entry"
  done
fi

# For systemd-boot
if [[ -d /boot/loader/entries ]]; then
  for entry in /boot/loader/entries/*.conf; do
    replace_os_name "$entry"
  done
fi

# For GRUB 
replace_os_name /etc/default/grub
if command -v grub-mkconfig >/dev/null 2>&1 && [[ -f /etc/default/grub ]]; then
  echo "If applying for GRUB, regenerate the config: sudo grub-mkconfig -o /boot/grub/grub.cfg"
fi

# Override CachyOS's limine auto-generator string if it exists
if [[ -f /etc/os-release ]]; then
  sed -i -E 's/PRETTY_NAME="[^"]*"/PRETTY_NAME="KakkuOS"/' /etc/os-release || true
fi

echo "Bootloader branding step complete."
