pkgname=kakku-niri-settings
pkgver=0.2.0
pkgrel=1
pkgdesc="KakkuOS niri and DankMaterialShell desktop defaults"
arch=('any')
url="https://kakkuos.jeme.app/"
license=('MIT')
install=kakku-niri-settings.install
depends=(
  'niri'
  'xwayland-satellite'
  'xdg-desktop-portal-gnome'
  'xdg-desktop-portal-gtk'
  'dms-shell-niri'
  'breeze-cursors'
  'swayidle'
  'wf-recorder'
  'grim'
  'slurp'
  'tesseract'
  'tesseract-data-eng'
  'tesseract-data-fin'
  'libnotify'
  'matugen'
  'qt6-imageformats'
  'qt6-multimedia'
  'qt6-multimedia-ffmpeg'
  'kimageformats'
  'cava'
  'khal'
  'wtype'
  'alacritty'
  'niri-screensaver'
  'power-profiles-daemon'
  'i2c-tools'
  'cups-pk-helper'
  'fprintd'
  'curl'
  'jq'
  'npm'
  'wl-clipboard'
  'ghostty'
  'fastfetch'
  'fontconfig'
  'ttf-jetbrains-mono-nerd'
  'fish'
  'zsh'
  'starship'
  'greetd'
  'greetd-dms-greeter-git'
)
source=()
sha256sums=()

package() {
  local repo_root="$startdir/../.."

  install -dm755 "$pkgdir/etc/skel/.config"
  cp -r "$repo_root/dotfiles/fastfetch" "$pkgdir/etc/skel/.config/fastfetch"
  cp -r "$repo_root/dotfiles/git" "$pkgdir/etc/skel/.config/git"
  cp -r "$repo_root/dotfiles/lazygit" "$pkgdir/etc/skel/.config/lazygit"
  cp -r "$repo_root/dotfiles/menus" "$pkgdir/etc/skel/.config/menus"
  cp -r "$repo_root/dotfiles/mpv" "$pkgdir/etc/skel/.config/mpv"
  cp -r "$repo_root/dotfiles/starship" "$pkgdir/etc/skel/.config/starship"
  cp -r "$repo_root/dotfiles/yazi" "$pkgdir/etc/skel/.config/yazi"
  cp -r "$repo_root/dotfiles/zathura" "$pkgdir/etc/skel/.config/zathura"
  cp -r "$repo_root/dotfiles/fish" "$pkgdir/etc/skel/.config/fish"
  cp -r "$repo_root/dotfiles/niri" "$pkgdir/etc/skel/.config/niri"
  cp -r "$repo_root/dotfiles/niri-screensaver" "$pkgdir/etc/skel/.config/niri-screensaver"
  cp -r "$repo_root/dotfiles/ghostty" "$pkgdir/etc/skel/.config/ghostty"
  cp -r "$repo_root/dotfiles/nvim" "$pkgdir/etc/skel/.config/nvim"
  cp -r "$repo_root/dotfiles/kakku" "$pkgdir/etc/skel/.config/kakku"
  cp -r "$repo_root/dotfiles/github-copilot" "$pkgdir/etc/skel/.config/github-copilot"
  cp -r "$repo_root/dotfiles/claude" "$pkgdir/etc/skel/.config/claude"
  install -Dm644 "$repo_root/system/dms/settings.defaults.json" "$pkgdir/etc/skel/.config/DankMaterialShell/settings.json"

  install -Dm644 "$repo_root/dotfiles/bash/.bashrc" "$pkgdir/etc/skel/.bashrc"
  install -Dm644 "$repo_root/dotfiles/zsh/.zshrc" "$pkgdir/etc/skel/.zshrc"

  install -dm755 "$pkgdir/usr/share/kakku/branding"
  cp -r "$repo_root/branding/." "$pkgdir/usr/share/kakku/branding/"
  install -Dm644 "$repo_root/branding/wallpaper.png" "$pkgdir/usr/share/backgrounds/kakku/wallpaper.png"
  if [[ -d "$repo_root/backgrounds" ]]; then
    install -dm755 "$pkgdir/usr/share/backgrounds/kakku"
    cp -r "$repo_root/backgrounds/." "$pkgdir/usr/share/backgrounds/kakku/"
  fi

  install -dm755 "$pkgdir/usr/share/kakku/packages"
  cp -r "$repo_root/packages/." "$pkgdir/usr/share/kakku/packages/"

  install -dm755 "$pkgdir/usr/share/kakku/browser"
  cp -r "$repo_root/system/browser/." "$pkgdir/usr/share/kakku/browser/"

  install -dm755 "$pkgdir/usr/share/kakku/dms"
  cp -r "$repo_root/system/dms/." "$pkgdir/usr/share/kakku/dms/"

  install -dm755 "$pkgdir/usr/bin"
  install -m755 "$repo_root"/bin/kakku "$pkgdir/usr/bin/"
  install -m755 "$repo_root"/bin/kakku-browser-policies "$pkgdir/usr/bin/"
  install -m755 "$repo_root"/bin/kakku-browser-theme "$pkgdir/usr/bin/"
  install -m755 "$repo_root"/bin/kakku-vscode-theme "$pkgdir/usr/bin/"
  install -m755 "$repo_root"/bin/kakku-defaults "$pkgdir/usr/bin/"
  install -m755 "$repo_root"/bin/kakku-disable-plymouth "$pkgdir/usr/bin/"
  install -m755 "$repo_root"/bin/kakku-firewall-defaults "$pkgdir/usr/bin/"
  install -m755 "$repo_root"/bin/kakku-edit "$pkgdir/usr/bin/"
  install -m755 "$repo_root"/bin/kakku-limine-defaults "$pkgdir/usr/bin/"
  install -m755 "$repo_root"/bin/kakku-ocr "$pkgdir/usr/bin/"
  install -m755 "$repo_root"/bin/kakku-record "$pkgdir/usr/bin/"
  install -m755 "$repo_root"/bin/niri-focus-fullscreen "$pkgdir/usr/bin/"

  install -Dm644 "$repo_root/system/xdg-desktop-portal/niri-portals.conf" "$pkgdir/usr/share/xdg-desktop-portal/niri-portals.conf"

  install -Dm644 "$repo_root/system/environment.d/kakku.conf" "$pkgdir/etc/environment.d/kakku.conf"

  install -Dm644 "$repo_root/system/greetd/config.toml" "$pkgdir/etc/greetd/config.toml"

  install -dm755 "$pkgdir/usr/share/kakku"
  install -Dm644 "$repo_root/system/default/limine" "$pkgdir/usr/share/kakku/default/limine"
  install -Dm644 "$repo_root/system/os-release" "$pkgdir/usr/share/kakku/os-release"
  install -Dm644 "$repo_root/README.md" "$pkgdir/usr/share/kakku/README.md"
}
